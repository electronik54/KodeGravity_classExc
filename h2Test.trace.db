-- Populate orders (120 rows)
INSERT INTO orders (customer_id, order_date, status)
SELECT
  ((X - 1) % 120) + 1,
  DATEADD('DAY', -MOD(X,365), CURRENT_TIMESTAMP()),
  CASE MOD(X,4)
    WHEN 0 THEN 'pending'
