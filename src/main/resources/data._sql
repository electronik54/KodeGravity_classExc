BEGIN TRANSACTION;

-- Temporarily disable referential checks (safe when truncating)
SET REFERENTIAL_INTEGRITY FALSE;

TRUNCATE TABLE book;

SET REFERENTIAL_INTEGRITY TRUE;

-- Insert 100 test rows with explicit ids 1..100
INSERT INTO book (id, name, author, stock, isbn, is_available)
SELECT
  X AS id,
  'Test Book ' || X AS name,
  'Author ' || (MOD(X, 10) + 1) AS author,
  10 + MOD(X, 20) AS stock,
  RIGHT('0000000000000' || CAST(1000000000000 + X AS VARCHAR), 13) AS isbn,
  CASE WHEN MOD(X, 2) = 0 THEN TRUE ELSE FALSE END AS is_available
FROM SYSTEM_RANGE(1, 100);

COMMIT;
